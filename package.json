{
  "name": "localtube",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run --workspaces --if-present dev",
    "build": "npm run --workspaces --if-present build",
    "start": "npm run build && node scripts/start-all.mjs",
    "start:all": "node scripts/start-all.mjs",
    "start:backend": "npm --workspace @localtube/backend run start",
    "start:frontend": "npm --workspace @localtube/frontend run preview",
    "test": "npm run --workspaces --if-present test",
    "typecheck": "npm run --workspaces --if-present typecheck"
  }
}
