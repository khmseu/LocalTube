{
  "name": "localtube",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "dev": "echo 'Run dev servers separately: npm run dev:backend and npm run dev:frontend'",
    "dev:backend": "npm --workspace @localtube/backend run dev",
    "dev:frontend": "npm --workspace @localtube/frontend run dev",
    "build": "npm run sync-version && npm run --workspaces --if-present build",
    "lint": "trunk check -ay --ignore \"plans/**\"",
    "start": "npm run build && npm run start:all",
    "start:all": "npm --workspace @localtube/backend run start:run",
    "start:backend": "npm --workspace @localtube/backend run start",
    "test": "npm run --workspaces --if-present test",
    "typecheck": "npm run --workspaces --if-present typecheck"
  }
}
